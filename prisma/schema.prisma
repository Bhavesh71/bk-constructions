generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
}

enum SiteStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model AppSettings {
  id                      String   @id @default(uuid())
  companyName             String   @default("BK Constructions")
  companyTagline          String?  @default("Operations")
  logoUrl                 String?
  currency                String   @default("INR")
  address                 String?
  phone                   String?
  email                   String?
  gstNumber               String?
  contactPerson           String?
  customExpenseCategories String?  @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  role           Role           @default(SUPERVISOR)
  theme          String         @default("light")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  dailyRecords   DailyRecord[]
  budgetEntries  BudgetEntry[]
  assignedSites  SiteUser[]
  weeklySalaries WeeklySalary[]
  voidedBudgets  BudgetEntry[]  @relation("BudgetVoidedBy")
  editedBudgets  BudgetEntry[]  @relation("BudgetEditedBy")
}

model Site {
  id              String        @id @default(cuid())
  name            String
  location        String
  status          SiteStatus    @default(ACTIVE)
  description     String?
  startDate       DateTime?
  expectedEndDate DateTime?
  expectedRevenue Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  dailyRecords    DailyRecord[]
  budgetEntries   BudgetEntry[]
  assignedUsers   SiteUser[]
}

model SiteUser {
  id        String   @id @default(cuid())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([siteId, userId])
}

model BudgetEntry {
  id          String    @id @default(cuid())
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  amount      Float
  note        String?
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  editedBy    User?     @relation("BudgetEditedBy", fields: [editedById], references: [id])
  editedById  String?
  isVoided    Boolean   @default(false)
  voidedAt    DateTime?
  voidedBy    User?     @relation("BudgetVoidedBy", fields: [voidedById], references: [id])
  voidedById  String?
  voidReason  String?
}

// grandTotal = totalMaterial + totalOther + totalLabour
// totalLabour starts 0; updated when weekly salary is paid
model DailyRecord {
  id              String          @id @default(cuid())
  site            Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId          String
  date            DateTime        @db.Date
  totalLabour     Float           @default(0)
  totalMaterial   Float           @default(0)
  totalOther      Float           @default(0)
  grandTotal      Float           @default(0)
  notes           String?
  createdBy       User            @relation(fields: [createdById], references: [id])
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  labourEntries   LabourEntry[]
  materialEntries MaterialEntry[]
  otherExpenses   OtherExpense[]
  labourAdvances  LabourAdvance[]

  @@unique([siteId, date])
}

model Labour {
  id             String          @id @default(cuid())
  name           String
  designation    String
  dailyWage      Float
  active         Boolean         @default(true)
  labourType     String          @default("REGULAR")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  labourEntries  LabourEntry[]
  advances       LabourAdvance[]
  weeklySalaries WeeklySalary[]
}

// isPaid=false until Pay Week; when paid → isPaid=true + DailyRecord totals updated
model LabourEntry {
  id            String      @id @default(cuid())
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  dailyRecordId String
  labour        Labour      @relation(fields: [labourId], references: [id])
  labourId      String
  rate          Float
  cost          Float
  present       Boolean     @default(true)
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())

  // Prevents duplicate entries for the same worker on the same day
  @@unique([dailyRecordId, labourId])
}

model LabourAdvance {
  id            String        @id @default(cuid())
  labour        Labour        @relation(fields: [labourId], references: [id], onDelete: Cascade)
  labourId      String
  amount        Float
  reason        String?
  dailyRecord   DailyRecord?  @relation(fields: [dailyRecordId], references: [id], onDelete: SetNull)
  dailyRecordId String?
  isSettled     Boolean       @default(false)
  settledAt     DateTime?
  weeklyPay     WeeklySalary? @relation(fields: [weeklyPayId], references: [id], onDelete: SetNull)
  weeklyPayId   String?
  createdAt     DateTime      @default(now())
}

model WeeklySalary {
  id              String          @id @default(cuid())
  labour          Labour          @relation(fields: [labourId], references: [id], onDelete: Cascade)
  labourId        String
  weekStart       DateTime        @db.Date
  weekEnd         DateTime        @db.Date
  daysWorked      Int
  totalWage       Float
  advanceDeducted Float           @default(0)
  netPaid         Float
  paidAt          DateTime        @default(now())
  paidBy          User            @relation(fields: [paidById], references: [id])
  paidById        String
  notes           String?
  advances        LabourAdvance[]
  createdAt       DateTime        @default(now())
}

model Material {
  id              String          @id @default(cuid())
  name            String
  unit            String
  defaultRate     Float
  category        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  materialEntries MaterialEntry[]
}

model MaterialEntry {
  id            String      @id @default(cuid())
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  dailyRecordId String
  material      Material    @relation(fields: [materialId], references: [id])
  materialId    String
  quantity      Float
  rate          Float
  total         Float
  createdAt     DateTime    @default(now())
}

model OtherExpense {
  id            String      @id @default(cuid())
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  dailyRecordId String
  category      String
  amount        Float
  description   String?
  createdAt     DateTime    @default(now())
}
